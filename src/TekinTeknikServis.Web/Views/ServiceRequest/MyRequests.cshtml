@model List<TekinTeknikServis.Core.Models.ServiceRequestForm>
@{
    ViewBag.Title = "Taleplerim";
    Layout = "_Layout";
}

<section class="auth-section" style="padding: 40px 20px;">
    <div class="page-container" style="max-width: 900px;">
        <h2 style="text-align: center; color: #1e3a8a; margin-bottom: 30px; font-size: 32px;">Servis Taleplerim</h2>

        @if (Model == null || !Model.Any())
        {
            <div style="background: white; padding: 40px; border-radius: 16px; text-align: center; box-shadow: 0 4px 15px rgba(0,0,0,0.05);">
                <i class="fas fa-history" style="font-size: 48px; color: #cbd5e1; margin-bottom: 15px;"></i>
                <p style="color: #64748b;">Henüz açmış olduğunuz bir servis talebi bulunmuyor.</p>
                <a href="@Url.Action("Index", "ServiceRequest")" class="btn" style="margin-top: 20px;">Yeni Talep Oluştur</a>
            </div>
        }
        else
        {
            <div style="display: flex; flex-direction: column; gap: 20px;">
                @foreach (var r in Model)
                {
                    <div style="background: white; border-radius: 16px; padding: 30px; box-shadow: 0 10px 25px -5px rgba(0,0,0,0.04); border: 1px solid #f1f5f9; border-left: 6px solid @(r.Durum == "Onaylandı" ? "#10b981" : r.Durum == "Reddedildi" ? "#ef4444" : "#f59e0b");">
                        <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 15px;">
                            <div>
                                <h3 style="margin: 0; color: #1e293b; font-size: 20px;">@r.CihazTuru</h3>
                                <span style="font-size: 13px; color: #94a3b8;"><i class="fas fa-clock"></i> Talep No: #@r.Id</span>
                            </div>
                            <span style="background: #f1f5f9; padding: 6px 14px; border-radius: 99px; font-size: 13px; font-weight: 600; color: #475569;">Durum: @r.Durum</span>
                        </div>
                        
                        <div style="background: #f8fafc; padding: 15px; border-radius: 10px; margin-bottom: 20px; color: #475569;">
                            <strong style="font-size: 13px; color: #94a3b8; display: block; margin-bottom: 5px;">Arıza Açıklamanız:</strong>
                            @r.ArizaAciklamasi
                        </div>

                        @if (!string.IsNullOrWhiteSpace(r.AdminCevabi))
                        {
                            <div style="background: #eff6ff; padding: 20px; border-radius: 12px; border-left: 4px solid #3b82f6; margin-bottom: 20px;">
                                <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 8px;">
                                    <i class="fas fa-user-cog" style="color: #3b82f6;"></i>
                                    <strong style="color: #1e40af; font-size: 15px;">Tekin Teknik Servis Yanıtı:</strong>
                                </div>
                                <p style="margin: 0; color: #1e40af; line-height: 1.6;">@r.AdminCevabi</p>
                            </div>

                            <form asp-controller="ServiceRequest" asp-action="UpdateReply" method="post" style="display: flex; gap: 10px; margin-top: 15px;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@r.Id" />
                                <input type="text" name="kullaniciCevabi" placeholder="Cevap veya ek açıklama yazın..." value="@r.KullaniciCevabi" class="form-input" style="flex: 1; border: 1px solid #e2e8f0;" />
                                <button type="submit" class="form-btn-primary" style="padding: 10px 25px;">Gönder</button>
                            </form>
                        }
                        else
                        {
                            <div style="font-size: 14px; color: #94a3b8; font-style: italic; background: #f8fafc; padding: 12px; border-radius: 8px; text-align: center;">
                                <i class="fas fa-spinner fa-spin"></i> Uzman ekibimiz talebinizi inceliyor, yanıt geldiğinde buradan mesajlaşabilirsiniz.
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>
</section>
