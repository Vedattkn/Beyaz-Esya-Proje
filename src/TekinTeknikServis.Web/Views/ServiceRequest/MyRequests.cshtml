@model List<TekinTeknikServis.Core.Models.ServiceRequestForm>
@{
    ViewBag.Title = "Taleplerim";
    Layout = "_Layout";
    long? selectedId = ViewBag.SelectedId != null ? (long)ViewBag.SelectedId : null;
}

<section class="user-chat-page">
    <div class="user-chat-shell">
        <h2>Servis Taleplerim</h2>

        @if (TempData["UserError"] != null)
        {
            <div class="validation-errors">@TempData["UserError"]</div>
        }

        @if (TempData["UserSuccess"] != null)
        {
            <div class="success-alert"><p>@TempData["UserSuccess"]</p></div>
        }

        @if (Model == null || !Model.Any())
        {
            <div class="user-chat-empty">
                <i class="fas fa-history"></i>
                <p>Henüz açmış olduğunuz bir servis talebi bulunmuyor.</p>
                <a href="@Url.Action("Index", "ServiceRequest")" class="btn">Yeni Talep Oluştur</a>
            </div>
        }
        else
        {
            <div class="user-chat-list">
                @foreach (var r in Model)
                {
                    var isSelected = selectedId.HasValue && r.Id == selectedId.Value;
                    var isClosed = string.Equals(r.Durum, "Kapatildi", StringComparison.OrdinalIgnoreCase)
                        || string.Equals(r.Durum, "Cozuldu", StringComparison.OrdinalIgnoreCase)
                        || string.Equals(r.Durum, "Kapali", StringComparison.OrdinalIgnoreCase)
                        || string.Equals(r.Durum, "Kapalı", StringComparison.OrdinalIgnoreCase);
                    <article class="user-chat-card @(isSelected ? "selected" : "")">
                        <header class="user-chat-card-header">
                            <div>
                                <h3>@r.CihazTuru</h3>
                                <div>Talep No: #@r.Id</div>
                            </div>
                            <span class="user-chat-status">@r.Durum</span>
                        </header>

                        <div class="user-chat-thread">
                            @if (r.SohbetMesajlari == null || !r.SohbetMesajlari.Any())
                            {
                                <div class="user-chat-empty">Mesaj geçmişi bulunamadı.</div>
                            }
                            else
                            {
                                @foreach (var msg in r.SohbetMesajlari)
                                {
                                    var roleClass = msg.Role == "admin" ? "admin" : msg.Role == "system" ? "system" : "user";
                                    <div class="chat-bubble-row @roleClass">
                                        <div class="chat-bubble @roleClass">
                                            <div class="chat-bubble-text">@msg.Text</div>
                                            <div class="chat-bubble-time">@msg.SentAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</div>
                                        </div>
                                    </div>
                                }
                            }
                        </div>

                        @if (isClosed)
                        {
                            <div class="user-chat-empty">Bu talep kapatıldı. Artık mesaj gönderemezsiniz.</div>
                        }
                        else
                        {
                            <form asp-controller="ServiceRequest" asp-action="UpdateReply" method="post" class="user-chat-reply-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@r.Id" />
                                <input type="text" name="kullaniciCevabi" class="form-input" placeholder="Cevabınızı yazın..." />
                                <button type="submit" class="btn">Cevap Ver</button>
                            </form>

                            <form asp-controller="ServiceRequest" asp-action="CloseAsSolved" method="post" class="user-chat-close-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@r.Id" />
                                <button type="submit" class="btn user-chat-close-btn" onclick="return confirm('Bu talebi çözüldü olarak kapatmak istiyor musunuz?');">Çözüldü Olarak Kapat</button>
                            </form>
                        }
                    </article>
                }
            </div>
        }
    </div>
</section>

@section Scripts {
    <script>
        document.querySelectorAll('.user-chat-thread').forEach(function (el) {
            el.scrollTop = el.scrollHeight;
        });
    </script>
}
