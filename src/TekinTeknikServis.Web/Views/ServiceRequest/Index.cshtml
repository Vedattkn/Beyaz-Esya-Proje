@model TekinTeknikServis.Core.Models.ServiceRequestForm
@{
    ViewBag.Title = "Servis Talep";
    Layout = "_Layout";
}

<section class="service-request-section">
    <div class="form-container">
        <div class="form-header">
            <i class="fas fa-tools"></i>
            <h2>Servis Talebi Oluştur</h2>
            <p>Aşağıdaki formu doldurarak uzman ekiplerimizin sizinle en kısa sürede iletişime geçmesini sağlayabilirsiniz.</p>
        </div>

        @if (ViewBag.Success == true)
        {
            <div class="success-alert">
                <i class="fas fa-check-circle"></i>
                <p>Servis talebiniz başarıyla alınmıştır! En kısa sürede sizinle iletişime geçilecektir.</p>
            </div>
        }

        <form asp-controller="ServiceRequest" asp-action="Index" method="post" class="modern-service-form">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="validation-errors"></div>

            <div class="form-group">
                <label asp-for="AdSoyad"><i class="fas fa-user"></i> Ad Soyad</label>
                <input asp-for="AdSoyad" placeholder="Adınızı ve soyadınızı giriniz" required />
                <span asp-validation-for="AdSoyad" class="error-text"></span>
            </div>

            <div class="form-group">
                <label asp-for="Telefon"><i class="fas fa-phone"></i> Telefon (11 Hane)</label>
                <input asp-for="Telefon" placeholder="05xxxxxxxxx" required maxlength="11" pattern="[0-9]{11}" />
                <span asp-validation-for="Telefon" class="error-text"></span>
            </div>

            <div class="form-group">
                <label asp-for="CihazTuru"><i class="fas fa-layer-group"></i> Kategori</label>
                <select asp-for="CihazTuru" class="form-input" style="width: 100%; height: auto;" required>
                    <option value="">Seçiniz</option>
                    @if (ViewBag.Categories != null)
                    {
                        foreach (string category in ViewBag.Categories)
                        {
                            <option value="@category">@category</option>
                        }
                    }
                </select>
                <span asp-validation-for="CihazTuru" class="error-text"></span>
            </div>

            <div class="form-group">
                <label asp-for="SecilenParcaId"><i class="fas fa-microchip"></i> Parça (İsteğe Bağlı)</label>
                <select asp-for="SecilenParcaId" id="secilenParca" class="form-input" style="width: 100%; height: auto;">
                    <option value="">Parça seçmek istemiyorum</option>
                    @if (ViewBag.Parts != null)
                    {
                        foreach (TekinTeknikServis.Core.Services.Product p in ViewBag.Parts)
                        {
                            <option value="@p.Id" data-category="@p.Category">@p.Name (@p.Category)</option>
                        }
                    }
                </select>
                <small class="service-form-hint">Önce kategori seçerseniz, parça listesi o kategoriye göre filtrelenir.</small>
                <span asp-validation-for="SecilenParcaId" class="error-text"></span>
            </div>

            <div class="form-group">
                <label asp-for="ArizaAciklamasi"><i class="fas fa-comment-alt"></i> Arıza Açıklaması</label>
                <textarea asp-for="ArizaAciklamasi" rows="4" placeholder="Cihazdaki sorunu kısaca anlatınız..." required></textarea>
                <span asp-validation-for="ArizaAciklamasi" class="error-text"></span>
            </div>

            <button type="submit" class="submit-btn">
                <span>Talebi Gönder</span>
                <i class="fas fa-paper-plane"></i>
            </button>
        </form>
    </div>
</section>

@section Scripts {
    <script>
        const categorySelect = document.getElementById('CihazTuru');
        const partSelect = document.getElementById('secilenParca');

        function filterPartsByCategory() {
            if (!categorySelect || !partSelect) return;

            const selectedCategory = categorySelect.value;
            const currentPartValue = partSelect.value;
            let hasCurrentOption = false;

            for (const option of partSelect.options) {
                if (!option.value) {
                    option.hidden = false;
                    continue;
                }

                const optionCategory = option.getAttribute('data-category') || '';
                const visible = !selectedCategory || optionCategory.toLowerCase() === selectedCategory.toLowerCase();
                option.hidden = !visible;
                if (visible && option.value === currentPartValue) {
                    hasCurrentOption = true;
                }
            }

            if (!hasCurrentOption && currentPartValue) {
                partSelect.value = '';
            }
        }

        if (categorySelect) {
            categorySelect.addEventListener('change', filterPartsByCategory);
        }

        filterPartsByCategory();
    </script>
}


