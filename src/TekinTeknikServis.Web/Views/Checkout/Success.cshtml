@{
    ViewBag.Title = "Ödeme Başarılı";
    Layout = "_Layout";
}

<section class="payment-success-page">
    <div class="payment-success-card">
        <div class="payment-success-icon">
        <i class="fas fa-check-circle"></i>
    </div>
        <h2>Ödeme Başarılı!</h2>
        <p class="payment-success-description">
        Siparişiniz başarıyla tamamlanmıştır. Kargo bilgileri e-mailinize gönderilecektir.
    </p>

        <div class="payment-summary-box">
            <div class="payment-summary-row">
            <span>Ödenen Tutar:</span>
            <strong>@ViewBag.TotalTry TL</strong>
        </div>
            <div class="payment-summary-row">
            <span>E-Mail:</span>
            <strong>@ViewBag.Email</strong>
        </div>
            <div class="payment-summary-row">
                <span>İşlem No:</span>
                <strong>@ViewBag.OrderNo</strong>
            </div>
            <div class="payment-summary-row">
            <span>İşlem Tarihi:</span>
            <strong>@System.DateTime.Now.ToString("dd.MM.yyyy")</strong>
        </div>
    </div>

        <div class="payment-success-actions">
            <a href="@Url.Action("Index","Home")" class="btn">Ana Sayfaya Dön</a>
            <a href="@Url.RouteUrl("urunler")" class="btn payment-continue-btn">Alışverişe Devam Et</a>
        </div>
    </div>
</section>

