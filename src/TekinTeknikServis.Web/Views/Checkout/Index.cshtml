@model TekinTeknikServis.Core.Models.CheckoutViewModel
@{
    ViewBag.Title = "Ödeme";
    Layout = "_Layout";
}

<section class="checkout-page">
    <div class="checkout-shell">
        <div class="checkout-summary">
            <h3>Sipariş Özeti</h3>
            @foreach (var item in Model.CartItems)
            {
                <div class="summary-row">
                    <span>@($"{item.Name} x{item.Quantity}")</span>
                    <span>@item.LineTotalTry TL</span>
                </div>
            }
            <div class="summary-row summary-total">
                <span>TOPLAM</span>
                <span>@Model.TotalTry TL</span>
            </div>
        </div>

        <form asp-controller="Checkout" asp-action="Complete" method="post" class="checkout-form">
        @Html.AntiForgeryToken()
        <h3>Kart Bilgileri</h3>

            <div asp-validation-summary="ModelOnly" class="checkout-validation-summary"></div>

            <div class="checkout-field">
                <label asp-for="AdSoyad">Ad Soyad *</label>
                <input asp-for="AdSoyad" placeholder="Adınız Soyadınız" class="checkout-input" autocomplete="name" />
                <span asp-validation-for="AdSoyad" class="checkout-field-error"></span>
        </div>

            <div class="checkout-field">
                <label asp-for="KartNo">Kart Numarası *</label>
                <input asp-for="KartNo" id="kartNo" maxlength="19" placeholder="1234 5678 9012 3456" inputmode="numeric" class="checkout-input" autocomplete="cc-number" />
                <span asp-validation-for="KartNo" class="checkout-field-error"></span>
        </div>

            <div class="checkout-row">
                <div class="checkout-field">
                    <label asp-for="SonKullanma">Son Kullanma Tarihi *</label>
                    <input asp-for="SonKullanma" id="sonKullanma" maxlength="5" placeholder="AA/YY" inputmode="numeric" class="checkout-input" autocomplete="cc-exp" />
                    <span asp-validation-for="SonKullanma" class="checkout-field-error"></span>
            </div>
                <div class="checkout-field">
                    <label asp-for="Cvc">CVC *</label>
                    <input asp-for="Cvc" id="cvc" maxlength="3" placeholder="123" inputmode="numeric" class="checkout-input" autocomplete="cc-csc" />
                    <span asp-validation-for="Cvc" class="checkout-field-error"></span>
                </div>
            </div>

            <div class="checkout-field">
                <label asp-for="Email">E-Mail *</label>
                <input asp-for="Email" placeholder="email@example.com" class="checkout-input" autocomplete="email" />
                <span asp-validation-for="Email" class="checkout-field-error"></span>
        </div>

            <div class="checkout-terms">
                <input asp-for="SartlarKabul" type="checkbox" />
                <label asp-for="SartlarKabul">Ödeme şartlarını kabul ediyorum</label>
            </div>
            <span asp-validation-for="SartlarKabul" class="checkout-field-error"></span>

            <div class="checkout-actions">
                <button type="submit" class="btn checkout-pay-btn">@Model.TotalTry TL Öde</button>
                <a href="@Url.RouteUrl("sepet")" class="btn checkout-cancel-btn">İptal Et</a>
            </div>
        </form>
        </div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const cardInput = document.getElementById('kartNo');
        const expiryInput = document.getElementById('sonKullanma');
        const cvcInput = document.getElementById('cvc');

        if (cardInput) {
            cardInput.addEventListener('input', function (e) {
                const digits = e.target.value.replace(/\D/g, '').slice(0, 16);
                const formatted = (digits.match(/.{1,4}/g) || []).join(' ');
                e.target.value = formatted;
            });
        }

        if (expiryInput) {
            expiryInput.addEventListener('input', function (e) {
                let value = e.target.value.replace(/\D/g, '').slice(0, 4);
                if (value.length >= 2) {
                    value = value.substring(0, 2) + '/' + value.substring(2);
                }
                e.target.value = value;
            });
        }

        if (cvcInput) {
            cvcInput.addEventListener('input', function (e) {
                e.target.value = e.target.value.replace(/\D/g, '').slice(0, 3);
            });
        }
    </script>
}
</section>

