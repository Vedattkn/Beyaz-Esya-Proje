@model TekinTeknikServis.Core.Services.Product
@{
    ViewBag.Title = "Yeni Ürün Ekle";
    Layout = "_Layout";
}

<div class="admin-card">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; border-bottom: 1px solid #f1f5f9; padding-bottom: 1rem;">
        <h2 style="margin: 0; color: #1e3a8a; font-size: 1.5rem;">Ürün Ekle</h2>
        <a href="@Url.Action("Products", "Admin")" style="text-decoration: none; color: #64748b; font-weight: 500;">
            <i class="fas fa-arrow-left"></i> Geri Dön
        </a>
    </div>

    @if (ViewBag.Success == true)
    {
        <div style="background: #f0fdf4; border: 1px solid #bbf7d0; color: #166534; padding: 1rem; border-radius: 8px; margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.75rem;">
            <i class="fas fa-check-circle" style="color: #22c55e;"></i>
            <span>Ürün başarıyla veritabanına eklendi!</span>
        </div>
    }

    <form asp-controller="Admin" asp-action="AddProduct" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" style="color: #dc2626; margin-bottom: 1rem;"></div>

        <div class="form-field">
            <label class="form-label">Ürün Adı</label>
            <input asp-for="Name" class="form-input" placeholder="Örn: Çamaşır Makinesi Motoru" required />
            <span asp-validation-for="Name" style="color: #dc2626; font-size: 0.8rem;"></span>
        </div>

        <div class="form-field">
            <label class="form-label">Kısa Açıklama</label>
            <input asp-for="Description" class="form-input" placeholder="Ürün hakkında kısa bilgi" required />
            <span asp-validation-for="Description" style="color: #dc2626; font-size: 0.8rem;"></span>
        </div>

        <div class="form-field">
            <label class="form-label">Fiyat (Görünen Metin)</label>
            <input asp-for="PriceText" class="form-input" placeholder="Örn: 1.500 TL" required />
            <span asp-validation-for="PriceText" style="color: #dc2626; font-size: 0.8rem;"></span>
        </div>

        <div class="form-field" style="background: #f8fafc; padding: 1.5rem; border-radius: 12px; border: 1px dashed #cbd5e1;">
            <label class="form-label">Ürün Fotoğrafı (.jpg, .png)</label>
            <p style="font-size: 0.8rem; color: #64748b; margin-bottom: 1rem;">
                <i class="fas fa-camera"></i> Sisteme yüklenecek görseli seçin.
            </p>
            <input type="file" name="ImageFile" accept="image/*" class="form-input" style="background: white;" required />
        </div>

        <div style="margin-top: 2rem;">
            <button type="submit" class="form-btn-primary" style="width: 100%; font-size: 1.1rem; padding: 1rem;">
                <i class="fas fa-plus"></i> Ürünü Sisteme Yükle
            </button>
        </div>
    </form>
</div>
