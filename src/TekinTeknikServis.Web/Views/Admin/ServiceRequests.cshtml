@model TekinTeknikServis.Core.Models.AdminServiceRequestsViewModel
@{
    ViewBag.Title = "Tüm Talepler";
    Layout = "_Layout";
}

<section class="admin-chat-page">
    <div class="admin-chat-shell">
        <div class="admin-chat-header">
            <h2><i class="fas fa-comments"></i> Tüm Servis Talepleri</h2>
            <span>Toplam: @(Model.Requests?.Count ?? 0) talep</span>
        </div>

        @if (TempData["AdminError"] != null)
        {
            <div class="admin-chat-error">
                <i class="fas fa-exclamation-triangle"></i> @TempData["AdminError"]
            </div>
        }

        @if (TempData["AdminSuccess"] != null)
        {
            <div class="success-alert">
                <p>@TempData["AdminSuccess"]</p>
            </div>
        }

        <div class="admin-chat-grid">
            <aside class="admin-chat-list-panel">
                <form method="get" asp-controller="Admin" asp-action="ServiceRequests" class="admin-chat-search">
                    <input type="text" name="q" value="@Model.Query" placeholder="İsim, telefon veya talep no ara..." />
                    <button type="submit" class="btn"><i class="fas fa-search"></i> Filtrele</button>
                </form>

                <div class="admin-chat-list">
                    @if (Model.Requests == null || !Model.Requests.Any())
                    {
                        <div class="admin-chat-empty">Eşleşen talep bulunamadı.</div>
                    }
                    else
                    {
                        @foreach (var req in Model.Requests)
                        {
                            var selected = Model.SelectedRequest?.Id == req.Id;
                            <a asp-controller="Admin"
                               asp-action="ServiceRequests"
                               asp-route-q="@Model.Query"
                               asp-route-selectedId="@req.Id"
                               class="admin-chat-list-item @(selected ? "active" : "")">
                                <div class="admin-chat-list-title">@req.AdSoyad</div>
                                <div class="admin-chat-list-meta">Talep #@req.Id • @req.Durum</div>
                                <div class="admin-chat-list-meta">@req.Telefon</div>
                            </a>
                        }
                    }
                </div>
            </aside>

            <section class="admin-chat-thread-panel">
                @if (Model.SelectedRequest == null)
                {
                    <div class="admin-chat-empty">Soldan bir talep seçin.</div>
                }
                else
                {
                    var r = Model.SelectedRequest;
                    var isClosed = string.Equals(r.Durum, "Kapatildi", StringComparison.OrdinalIgnoreCase)
                        || string.Equals(r.Durum, "Cozuldu", StringComparison.OrdinalIgnoreCase)
                        || string.Equals(r.Durum, "Kapali", StringComparison.OrdinalIgnoreCase)
                        || string.Equals(r.Durum, "Kapalı", StringComparison.OrdinalIgnoreCase);
                    var nextStatusButtonText = string.Equals(r.Durum, "Inceleniyor", StringComparison.OrdinalIgnoreCase)
                        ? "Talebi Kapat"
                        : "İnceleniyor Yap";
                    <div class="admin-chat-thread-header">
                        <div>
                            <h3>@r.AdSoyad</h3>
                            <div>Talep No: #@r.Id • Kategori: @r.CihazTuru • Durum: @r.Durum</div>
                        </div>
                        <div>@(r.KayitTarihi?.ToString("dd.MM.yyyy HH:mm"))</div>
                    </div>

                    <div class="admin-chat-thread-body">
                        @if (r.SohbetMesajlari == null || !r.SohbetMesajlari.Any())
                        {
                            <div class="admin-chat-empty">Bu talepte henüz mesaj yok.</div>
                        }
                        else
                        {
                            @foreach (var msg in r.SohbetMesajlari)
                            {
                                var roleClass = msg.Role == "admin" ? "admin" : msg.Role == "system" ? "system" : "user";
                                <div class="chat-bubble-row @roleClass">
                                    <div class="chat-bubble @roleClass">
                                        <div class="chat-bubble-text">@msg.Text</div>
                                        <div class="chat-bubble-time">@msg.SentAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</div>
                                    </div>
                                </div>
                            }
                        }
                    </div>

                    @if (isClosed)
                    {
                        <div class="admin-chat-empty">Bu talep kapatıldı. Artık admin ve müşteri mesaj gönderemez.</div>
                    }
                    else
                    {
                        <form asp-controller="Admin" asp-action="UpdateServiceRequest" method="post" class="admin-chat-actions-form">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@r.Id" />
                            <input type="hidden" name="q" value="@Model.Query" />

                            <label for="adminCevabi">Admin Cevabı</label>
                            <textarea id="adminCevabi" name="adminCevabi" class="form-input" rows="3" placeholder="Müşteriye gönderilecek yeni mesajı yazın..."></textarea>

                            <div class="admin-chat-action-buttons">
                                <button type="submit" class="btn">Mesaj Gönder</button>
                            </div>
                        </form>

                        <form asp-controller="Admin" asp-action="AdvanceServiceRequestStatus" method="post" class="admin-chat-actions-form" style="padding-top:0;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@r.Id" />
                            <input type="hidden" name="q" value="@Model.Query" />
                            <div class="admin-chat-action-buttons">
                                <button type="submit" class="btn">@nextStatusButtonText</button>
                            </div>
                        </form>
                    }

                    <form asp-controller="Admin" asp-action="DeleteServiceRequest" method="post" class="admin-chat-actions-form" style="padding-top:0;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@r.Id" />
                        <input type="hidden" name="q" value="@Model.Query" />
                        <div class="admin-chat-action-buttons">
                            <button type="submit" class="btn admin-chat-close" onclick="return confirm('Bu sohbet kaydını kalıcı olarak silmek istediğinize emin misiniz?');">Sohbeti Sil</button>
                        </div>
                    </form>
                }
            </section>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        document.querySelectorAll('.admin-chat-thread-body').forEach(function (el) {
            el.scrollTop = el.scrollHeight;
        });
    </script>
}
