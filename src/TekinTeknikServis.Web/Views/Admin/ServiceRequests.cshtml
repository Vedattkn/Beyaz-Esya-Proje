@model List<TekinTeknikServis.Core.Models.ServiceRequestForm>
@{
    ViewBag.Title = "Tüm Talepler";
    Layout = "_Layout";
}

<section class="admin-panel" style="padding: 40px 20px;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px;">
        <h2 style="color: #1e3a8a; font-size: 28px; margin: 0;"><i class="fas fa-list-alt"></i> Tüm Servis Talepleri</h2>
        <span style="color: #64748b; font-size: 14px;">Toplam: @(Model?.Count ?? 0) Talep</span>
    </div>

    @if (TempData["AdminError"] != null)
    {
        <div style="background: #fef2f2; border: 1px solid #fee2e2; color: #dc2626; padding: 15px; border-radius: 10px; margin-bottom: 25px;">
            <i class="fas fa-exclamation-triangle"></i> @TempData["AdminError"]
        </div>
    }

    @if (Model == null || !Model.Any())
    {
        <div style="text-align: center; padding: 50px; background: white; border-radius: 16px; box-shadow: 0 4px 10px rgba(0,0,0,0.05);">
            <i class="fas fa-inbox" style="font-size: 48px; color: #cbd5e1; margin-bottom: 15px;"></i>
            <p style="color: #64748b; font-size: 18px;">Henüz bir servis talebi bulunmuyor.</p>
        </div>
    }
    else
    {
        <div style="display: flex; flex-direction: column; gap: 25px;">
            @foreach (var r in Model)
            {
                <div style="background: white; padding: 25px; border-radius: 16px; box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05); border-left: 6px solid @(r.Durum == "Onaylandı" ? "#10b981" : r.Durum == "Reddedildi" ? "#ef4444" : "#f59e0b");">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 15px;">
                        <div>
                            <span style="font-weight: 800; font-size: 20px; color: #1e293b; display: block;">@r.AdSoyad</span>
                            <div style="display: flex; gap: 15px; font-size: 14px; color: #64748b;">
                                <span><i class="fas fa-phone-alt"></i> @r.Telefon</span>
                                <span><i class="fas fa-calendar-alt"></i> @(r.KayitTarihi?.ToString("dd/MM/yyyy HH:mm"))</span>
                            </div>
                        </div>
                        <span style="background: #f1f5f9; padding: 6px 12px; border-radius: 89px; font-size: 13px; font-weight: 700; color: #475569;">Cihaz: @r.CihazTuru</span>
                    </div>

                    <div style="background: #f8fafc; padding: 15px; border-radius: 10px; margin-bottom: 20px; border: 1px solid #f1f5f9;">
                        <strong style="display: block; font-size: 12px; color: #94a3b8; text-transform: uppercase; margin-bottom: 5px;">Müşteri Arıza Açıklaması</strong>
                        @r.ArizaAciklamasi
                    </div>
                    
                    @if (!string.IsNullOrWhiteSpace(r.KullaniciCevabi))
                    {
                        <div style="background: #fff7ed; padding: 15px; border-radius: 10px; border: 1px solid #ffedd5; margin-bottom: 20px;">
                            <strong style="color: #ea580c; display: block; font-size: 13px; margin-bottom: 5px;"><i class="fas fa-user-edit"></i> Müşteriden Ek Mesaj:</strong>
                            @r.KullaniciCevabi
                        </div>
                    }

                    <form asp-controller="Admin" asp-action="UpdateServiceRequest" method="post" style="display: flex; flex-wrap: wrap; gap: 20px; align-items: flex-end; background: #f1f5f9; padding: 20px; border-radius: 12px;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@r.Id" />
                        
                        <div style="flex: 1; min-width: 300px;">
                            <label class="form-label" style="font-weight: 700; color: #1e3a8a;"><i class="fas fa-comment-dots"></i> Admin Yanıtı (Müşteriye Gönderilir)</label>
                            <textarea name="adminCevabi" class="form-input" rows="3" style="width: 100%; border: 1px solid #cbd5e1; resize: none; margin-top: 8px;">@r.AdminCevabi</textarea>
                        </div>
                        
                        <div style="width: 180px;">
                            <label class="form-label" style="font-weight: 700; color: #1e3a8a;"><i class="fas fa-tasks"></i> Durum</label>
                            <select name="durum" class="form-input" style="width: 100%; height: auto; padding: 0.7rem; margin-top: 8px;">
                                <option value="Bekliyor" selected="@(r.Durum == "Bekliyor")">Bekliyor (Yeni)</option>
                                <option value="Onaylandı" selected="@(r.Durum == "Onaylandı")">Onaylandı</option>
                                <option value="İncelendi" selected="@(r.Durum == "İncelendi")">İncelendi</option>
                                <option value="Reddedildi" selected="@(r.Durum == "Reddedildi")">Reddedildi</option>
                            </select>
                        </div>

                        <button type="submit" class="form-btn-primary" style="height: 50px; padding: 0 40px; font-size: 16px;">
                            <i class="fas fa-sync-alt"></i> Güncelle ve Kaydet
                        </button>
                    </form>
                </div>
            }
        </div>
    }
</section>
