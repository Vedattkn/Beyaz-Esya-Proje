@model System.Collections.Generic.List<TekinTeknikServis.Core.Models.CartItem>
@{
    ViewBag.Title = "Alışveriş Sepeti";
    Layout = "_Layout";
}

<section class="cart-page">
    <div class="cart-shell">
        <div class="cart-header">
            <h1>Sepetim</h1>
            <p>Seçtiğiniz ürünleri kontrol edip ödeme adımına geçebilirsiniz.</p>
        </div>

        @if (TempData["CheckoutError"] is string checkoutError && !string.IsNullOrWhiteSpace(checkoutError))
        {
            <div class="checkout-warning">
                <i class="fas fa-circle-exclamation" aria-hidden="true"></i>
                <span>@checkoutError</span>
            </div>
        }

    @if (Model == null || Model.Count == 0)
    {
            <div class="empty-cart">
                <i class="fas fa-cart-shopping" aria-hidden="true"></i>
            <h2>Sepetiniz boş</h2>
            <p>Lütfen ürünler sayfasından ürün seçiniz.</p>
            <a href="@Url.RouteUrl("urunler")" class="btn">Ürünleri Görüntüle</a>
        </div>
    }
    else
    {
            <div class="cart-table-wrap">
                <table class="cart-table">
            <thead>
                <tr>
                                <th>Ürün Adı</th>
                                <th>Fiyat</th>
                                <th>Miktar</th>
                                <th>Toplam</th>
                                <th>İşlem</th>
                </tr>
            </thead>
            <tbody>
                @for (var i = 0; i < Model.Count; i++)
                {
                    var item = Model[i];
                    <tr>
                                    <td data-label="Ürün Adı">@item.Name</td>
                                    <td data-label="Fiyat">@item.PriceText</td>
                                    <td data-label="Miktar">
                            <form asp-controller="Cart" asp-action="UpdateQuantity" method="post" class="quantity-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="index" value="@i" />
                                <input type="number" name="quantity" value="@item.Quantity" min="1" class="quantity-input" onchange="this.form.submit()" />
                            </form>
                        </td>
                                    <td data-label="Toplam">@item.LineTotalTry TL</td>
                                    <td data-label="İşlem">
                            <form asp-controller="Cart" asp-action="RemoveAt" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="index" value="@i" />
                                            <button type="submit" class="remove-item-btn">
                                    <i class="fas fa-trash"></i> Sil
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
            </div>

            <div class="cart-total-box">
                <div class="cart-total-price">
                Toplam: @ViewBag.TotalTry TL
            </div>
                <div class="cart-actions">
                    <a href="@Url.RouteUrl("odeme")" class="btn cart-checkout-btn">Ödeme Yap</a>
                    <a href="@Url.RouteUrl("urunler")" class="btn cart-continue-btn">Alışverişe Devam Et</a>
                </div>
        </div>
    }
</div>
</section>

