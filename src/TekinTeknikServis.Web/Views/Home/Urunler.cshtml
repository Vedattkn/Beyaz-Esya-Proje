@using TekinTeknikServis.Core.Services
@model List<Product>
@{
    ViewBag.Title = "Ürünler";
    Layout = "_Layout";

    var searchTerm = ViewBag.SearchTerm as string ?? string.Empty;
    var hasSearch = !string.IsNullOrWhiteSpace(searchTerm);
    var totalProductCount = Model?.Count ?? 0;
    var categoryCount = Model?
        .Where(x => !string.IsNullOrWhiteSpace(x.Category))
        .Select(x => x.Category)
        .Distinct()
        .Count() ?? 0;
}

<section class="products-section products-theme">
    <div class="products-wrapper">
        <div class="section-header">
            <span class="section-kicker">Tekin Teknik Servis</span>
            <h1 class="section-title">Yedek Parça Galerisi</h1>
            <p class="section-subtitle">Kaliteli, uzun ömürlü ve servis güvenceli ürünleri tek ekranda keşfedin.</p>

            <div class="products-stats">
                <div class="stat-pill">
                    <i class="fas fa-cubes"></i>
                    <span>@totalProductCount ürün</span>
                </div>
                <div class="stat-pill">
                    <i class="fas fa-layer-group"></i>
                    <span>@categoryCount kategori</span>
                </div>
                <div class="stat-pill">
                    <i class="fas fa-shield-alt"></i>
                    <span>Servis destekli</span>
                </div>
            </div>
        </div>

        <div class="search-section">
            <form method="get" action="@Url.RouteUrl("urunler")" class="search-form">
                <div class="search-input-group">
                    <i class="fas fa-search search-icon"></i>
                    <input type="text" 
                           name="search" 
                           class="search-input" 
                           placeholder="Ürün ara... (Örn: Buzdolabı, Çamaşır Makinesi)" 
                           value="@searchTerm"
                           aria-label="Ürün arama"
                           autocomplete="off" />
                    <button type="submit" class="search-submit">Ara</button>
                    @if (hasSearch)
                    {
                        <a href="@Url.RouteUrl("urunler")" class="search-clear">
                            <i class="fas fa-times"></i> Temizle
                        </a>
                    }
                </div>
            </form>
            @if (hasSearch)
            {
                <div class="search-results-info">
                    <span class="badge-search"><i class="fas fa-filter"></i> "@searchTerm" için <strong>@totalProductCount</strong> ürün bulundu</span>
                </div>
            }
        </div>

        <div class="products-grid">
            @if (Model == null || Model.Count == 0)
            {
                <div class="no-products">
                    <i class="fas fa-box-open"></i>
                    <h3>Ürün bulunamadı</h3>
                    <p>
                        @if (hasSearch)
                        {
                            <span>"@searchTerm" için ürün bulunamadı. Lütfen farklı bir arama terimi deneyin.</span>
                        }
                        else
                        {
                            <span>Şu anda gösterilecek ürün yok.</span>
                        }
                    </p>
                    @if (hasSearch)
                    {
                        <a href="@Url.RouteUrl("urunler")" class="btn-back-products">Tüm Ürünleri Gör</a>
                    }
                </div>
            }
            else
            {
                @for (var cardIndex = 0; cardIndex < Model.Count; cardIndex++)
                {
                    var p = Model[cardIndex];
                    <article class="product-item" style="--item-index:@cardIndex">
                        <div class="product-image-container">
                            <img src="@p.ImageUrl" alt="@p.Name" class="product-image" loading="lazy" />
                            <div class="product-overlay">
                                <a href="@Url.RouteUrl("urun-detay", new { id = p.Id })" class="btn-view-detail">
                                    <i class="fas fa-eye"></i> İncele
                                </a>
                            </div>
                            <span class="product-category-badge">@p.Category</span>
                        </div>
                        
                        <div class="product-body">
                            <h3 class="product-title">@p.Name</h3>
                            <p class="product-description">@p.Description</p>
                            <div class="product-price-section">
                                <span class="product-price">@p.PriceText</span>
                            </div>
                            
                            <div class="product-footer">
                                <a href="@Url.RouteUrl("urun-detay", new { id = p.Id })" class="btn btn-outline-secondary btn-sm">
                                    <i class="fas fa-info-circle"></i> Detay
                                </a>
                                <form asp-controller="Cart" asp-action="Add" asp-route-id="@p.Id" method="post" class="form-add-cart">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-danger btn-sm">
                                        <i class="fas fa-cart-plus"></i> Sepete Ekle
                                    </button>
                                </form>
                            </div>
                        </div>
                    </article>
                }
            }
        </div>
    </div>
</section>