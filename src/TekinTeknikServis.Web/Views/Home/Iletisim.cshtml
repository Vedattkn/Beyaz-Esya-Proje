@{
    ViewBag.Title = "İletişim";
    Layout = "_Layout";
}

<section class="contact-section">
    <div class="contact-header">
        <h2>Bize Ulaşın</h2>
        <p>Size daha iyi hizmet verebilmek için buradayız. Sorularınız veya servis talepleriniz için bize ulaşabilirsiniz.</p>
    </div>

    <div class="contact-container">
        <!-- İletişim Bilgileri -->
        <div class="contact-card-grid">
            <div class="contact-item-card">
                <i class="fas fa-phone-alt"></i>
                <h3>Telefon</h3>
                <p>Müşteri Hizmetleri:</p>
                <a href="tel:05345224487">0541 457 46 09</a>
            </div>

            <div class="contact-item-card">
                <i class="fas fa-envelope"></i>
                <h3>E-Posta</h3>
                <p>Genel Destek:</p>
                <a href="mailto:vedattkn@gmail.com">vedattkn@gmail.com</a>
            </div>

            <div class="contact-item-card">
                <i class="fas fa-map-marker-alt"></i>
                <h3>Adres</h3>
                <p>Van Merkez</p>
                <span>İpekyolu, Van</span>
            </div>

            <div class="contact-item-card">
                <i class="fas fa-clock"></i>
                <h3>Çalışma Saatleri</h3>
                <p>Pazartesi - Cuma: 09:00 - 19:00</p>
                <p>Cumartesi: 10:00 - 16:00</p>
                <p class="hours-closed"><strong>Pazar: Kapalı</strong></p>
                <p class="hours-note">Acil durumlarda 7/24 ulaşabilirsiniz.</p>
            </div>
        </div>


        <div class="contact-action">
            <div class="action-card">
                <h3>Acil Teknik Destek Lazım mı?</h3>
                <p>Hemen çevrimiçi servis talebi formunu doldurarak uzman ekiplerimizin size ulaşmasını sağlayın.</p>
                <a href="@Url.Action("Index","ServiceRequest")" class="btn btn-primary">Hemen Servis Talebi Oluştur</a>
                <div class="contact-short-actions">
                    <div class="contact-action-item">
                        <a class="home-contact-action call round-action" href="tel:05345224487" aria-label="Bizi ara">
                            <i class="fas fa-phone"></i>
                            <span class="sr-only">Ara</span>
                        </a>
                    </div>
                    <div class="contact-action-item">
                        <a class="home-contact-action whatsapp round-action" href="https://wa.me/905345224487" target="_blank" rel="noopener" aria-label="WhatsApp mesajı gönder">
                            <i class="fab fa-whatsapp"></i>
                            <span class="sr-only">WhatsApp</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>

    .hours-closed {
        color: #b91c1c;
        font-weight: 700;
        margin-top: 6px;
    }

    .hours-note {
        margin-top: 6px;
        background: #ecfeff;
        color: #0e7490;
        border: 1px solid #67e8f9;
        padding: 6px 8px;
        border-radius: 8px;
        display: inline-block;
        font-weight: 600;
        font-size: 12px;
    }

    .contact-short-actions {
        display: flex;
        gap: 10px;
        align-items: center;
        flex-wrap: wrap;
    }

    .contact-action-item {
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .round-action {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        color: #ffffff;
        font-size: 18px;
        border: 1px solid transparent;
    }

    .home-contact-action.call.round-action {
        background: #0ea5e9;
        border-color: #0284c7;
        box-shadow: 0 10px 18px rgba(14, 165, 233, 0.25);
    }

    .home-contact-action.whatsapp.round-action {
        background: #25d366;
        border-color: #1da851;
        box-shadow: 0 10px 18px rgba(37, 211, 102, 0.35);
    }

</style>


