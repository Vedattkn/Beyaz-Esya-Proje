@{
    ViewBag.Title = "Tekin Teknik Servis";
    Layout = "_Layout";
}

<section class="hero">
    <div class="page-container">
        <h1>Tekin Teknik Servis ile Güvenli Bakım</h1>
        <p>Buzdolabı, çamaşır ve bulaşık makineniz için profesyonel çözümler</p>
        <a href="@Url.Action("Index","ServiceRequest")" class="btn"><i class="fas fa-tools"></i> Hemen Servis Talebi Oluştur</a>
    </div>
</section>

<section class="services" style="padding: 40px 20px;">
    <div class="page-container" style="max-width: 1400px;">
        <h2 style="text-align: center; margin-bottom: 30px;">Hizmetlerimiz</h2>

        <div class="service-container" style="gap: 20px;">
            <div class="card">
                <i class="fas fa-snowflake" style="font-size: 50px; color: #3b82f6; margin-bottom: 20px;"></i>
                <h3>Buzdolabı Servisi</h3>
                <p>Aniden bozulan buzdolaplarınız için aynı gün tamir ve bakım desteği veriyoruz.</p>
            </div>

            <div class="card">
                <i class="fas fa-tshirt" style="font-size: 50px; color: #3b82f6; margin-bottom: 20px;"></i>
                <h3>Çamaşır Makinesi Servisi</h3>
                <p>Parça değişimi ve arıza tespitleri için profesyonel servis ekibimiz yanınızda.</p>
            </div>

            <div class="card">
                <i class="fas fa-water" style="font-size: 50px; color: #3b82f6; margin-bottom: 20px;"></i>
                <h3>Bulaşık Makinesi</h3>
                <p>Su kaçağı, program hatası gibi tüm sorunlarda yerinde servis sağlıyoruz.</p>
            </div>

            <div class="card">
                <i class="fas fa-fire" style="font-size: 50px; color: #3b82f6; margin-bottom: 20px;"></i>
                <h3>Ankastra Fırın Servisi</h3>
                <p>Ankastra fırınların tüm arızalarında hızlı ve güvenilir servis hizmeti sunuyoruz.</p>
            </div>

            <div class="card">
                <i class="fas fa-fan" style="font-size: 50px; color: #3b82f6; margin-bottom: 20px;"></i>
                <h3>Kurutma Makinesi Servisi</h3>
                <p>Kurutma makinesi arızaları ve bakımı için profesyonel teknikçilerimiz hizmetinizdedir.</p>
            </div>

            <div class="card">
                <i class="fas fa-droplet" style="font-size: 50px; color: #3b82f6; margin-bottom: 20px;"></i>
                <h3>Termosifon Servisi</h3>
                <p>Termosifon onarımı, bakımı ve limanlama işlemlerini güvenli şekilde yapıyoruz.</p>
            </div>

            <div class="card">
                <i class="fas fa-plug" style="font-size: 50px; color: #3b82f6; margin-bottom: 20px;"></i>
                <h3>Küçük Ev Aletleri</h3>
                <p>Mikrodalga, elektrikli ısıtıcı, kahvehane ve diğer küçük ev aletlerinin tamiri.</p>
            </div>
        </div>
    </div>
</section>
