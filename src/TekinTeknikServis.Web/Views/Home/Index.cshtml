@{
    ViewBag.Title = "Tekin Teknik Servis";
    Layout = "_Layout";
}

<section class="hero">
    <div class="hero-shapes" aria-hidden="true">
        <span class="hero-shape hero-shape-one"></span>
        <span class="hero-shape hero-shape-two"></span>
    </div>
    <div class="page-container">
        <h1>Tekin Teknik Servis ile Güvenli Bakım</h1>
        <p>Buzdolabı Servisi, Çamaşır Makinesi Servisi, Bulaşık Makinesi Servisi, Ankastra (Fırın) Servisi, Kurutma Makinesi servisi, Termosifon Servisi, Küçük Ev Aletleri servisi</p>
        <a href="@Url.Action("Index","ServiceRequest")" class="btn"><i class="fas fa-tools"></i> Hemen Servis Talebi Oluştur</a>
    </div>
</section>

<section class="trust-bar">
    <div class="page-container trust-bar-inner">
        <div class="trust-item">
            <div class="trust-icon"><i class="fas fa-briefcase"></i></div>
            <div class="trust-text">
                <span class="trust-count js-countup" data-target="10" data-suffix="+" data-duration="2000">0</span>
                <span class="trust-label">Yil Tecrube</span>
            </div>
        </div>
        <div class="trust-item">
            <div class="trust-icon"><i class="fas fa-users"></i></div>
            <div class="trust-text">
                <span class="trust-count js-countup" data-target="1000" data-suffix="+" data-duration="2600">0</span>
                <span class="trust-label">Mutlu Musteri</span>
            </div>
        </div>
        <div class="trust-item">
            <div class="trust-icon"><i class="fas fa-bolt"></i></div>
            <div class="trust-text">
                <span class="trust-count">Ayni gun</span>
                <span class="trust-label">Servis</span>
            </div>
        </div>
    </div>
</section>

<section class="home-testimonials">
    <div class="page-container">
        <div class="section-header">
            <h2>Müşteri Yorumlari</h2>
            <p>Guven veren servis deneyimleriyle yaninizdayiz.</p>
        </div>
        <div class="testimonial-grid">
            <div class="testimonial-card">
                <div class="testimonial-stars" aria-label="4 yildiz">
                    <i class="fas fa-star"></i>
                    <i class="fas fa-star"></i>
                    <i class="fas fa-star"></i>
                    <i class="fas fa-star"></i>
                </div>
                <p class="testimonial-quote">WhatsApp uzerinden hizli donus yaptilar, servis sureci cok rahatti. Hem hizli hem guler yuzlu hizmet aldim, kesinlikle tavsiye ederim.</p>
                <div class="testimonial-meta">Seda T.</div>
            </div>
            <div class="testimonial-card">
                <div class="testimonial-stars" aria-label="5 yildiz">
                    <i class="fas fa-star"></i>
                    <i class="fas fa-star"></i>
                    <i class="fas fa-star"></i>
                    <i class="fas fa-star"></i>
                    <i class="fas fa-star"></i>
                </div>
                <p class="testimonial-quote">Camasir makinesi sorunumu kisa surede cozduler, tesekkur ederim. Gercekten guvenilir bir servis.</p>
                <div class="testimonial-meta">Ahmet Y.</div>
            </div>
            <div class="testimonial-card">
                <div class="testimonial-stars" aria-label="3 yildiz">
                    <i class="fas fa-star"></i>
                    <i class="fas fa-star"></i>
                    <i class="fas fa-star"></i>
                </div>
                <p class="testimonial-quote">Fiyat performans olarak çok iyi.</p>
                <div class="testimonial-meta">Nermin D.</div>
            </div>
            <div class="testimonial-card">
                <div class="testimonial-stars" aria-label="2 yildiz">
                    <i class="fas fa-star"></i>
                    <i class="fas fa-star"></i>
                </div>
                <p class="testimonial-quote">Sorunum cozuldu ama daha hizli olunabilirdi. Fiyat performans acisindan ortalama bir hizmetti.</p>
                <div class="testimonial-meta">Kenan O.</div>
            </div>
        </div>
    </div>
</section>

<section class="home-brands">
    <div class="page-container">
        <div class="section-header">
            <h2>Hangi Markalara Hizmet Veriyoruz</h2>
            <p>Geniş marka yelpazemiz ile aynı gün servis desteği sağlıyoruz.</p>
        </div>
        <div class="brand-group-grid">
            <div class="brand-group-card">
                <div class="brand-group-title">Arçelik Grubu</div>
                <div class="brand-chip-list">
                    <span class="brand-chip">Arçelik</span>
                    <span class="brand-chip">Beko</span>
                    <span class="brand-chip">Altus</span>
                    <span class="brand-chip">Grundig</span>
                </div>
            </div>
            <div class="brand-group-card">
                <div class="brand-group-title">Vestel Grubu</div>
                <div class="brand-chip-list">
                    <span class="brand-chip">Vestel</span>
                    <span class="brand-chip">Regal</span>
                    <span class="brand-chip">Finlux</span>
                    <span class="brand-chip">SEG</span>
                </div>
            </div>
            <div class="brand-group-card">
                <div class="brand-group-title">Bosch Grubu</div>
                <div class="brand-chip-list">
                    <span class="brand-chip">Bosch</span>
                    <span class="brand-chip">Siemens</span>
                    <span class="brand-chip">Profilo</span>
                    <span class="brand-chip">Gaggenau</span>
                </div>
            </div>
            <div class="brand-group-card">
                <div class="brand-group-title">Global ve Diğer Markalar</div>
                <div class="brand-chip-list">
                    <span class="brand-chip">Samsung</span>
                    <span class="brand-chip">LG</span>
                    <span class="brand-chip">Ariston</span>
                    <span class="brand-chip">Electrolux</span>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="location-section">
    <div class="page-container">
        <div class="section-header">
            <h2>Isletme Konumu</h2>
            <p>Hizlica yol tarifi alin, bizi kolayca bulun.</p>
        </div>
        <div class="location-card">
            <div class="location-map" aria-label="Tekin Teknik Servis konumu haritada">
                <iframe
                    title="Tekin Teknik Servis Google Maps"
                    src="https://www.google.com/maps?q=38.50393,43.4301483&z=15&output=embed"
                    loading="lazy"
                    referrerpolicy="no-referrer-when-downgrade"
                    allowfullscreen>
                </iframe>
            </div>
            <div class="location-info">
                <h3>Tekin Teknik Servis</h3>
                <p>Van / Ipekyolu / Merkez</p>
                <p><strong>Telefon:</strong> 0541 457 46 09</p>
                <div class="location-actions">
                    <a
                        class="btn btn-primary location-btn"
                        href="https://www.google.com/maps?q=38.50393,43.4301483"
                        target="_blank"
                        rel="noopener">
                        <i class="fas fa-route"></i> Yol Tarifi Al
                    </a>
                    <a class="location-btn-secondary" href="tel:05414574609">
                        <i class="fas fa-phone"></i> Hemen Ara
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>



