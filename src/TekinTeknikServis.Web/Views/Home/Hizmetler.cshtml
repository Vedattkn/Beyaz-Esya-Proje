@{
    ViewBag.Title = "Hizmetlerimiz - Tekin Teknik Servis";
    Layout = "_Layout";
}

<section class="services-page-section" style="padding: 60px 20px; min-height: 60vh;">
    <div style="text-align: center; margin-bottom: 40px;">
        <h2 style="color: #1e3a8a; font-size: 32px;">Hizmetlerimiz</h2>
        <p style="color: #64748b; font-size: 16px;">Sizlere sunduğumuz profesyonel bakım ve onarım çözümleri</p>
    </div>

    <div class="service-container">
        
        <a href="@Url.Action("Index", "ServiceRequest", new { kategori = "Buzdolabı" })" class="service-link">
            <div class="card service-card featured">
                <span class="service-badge">En Çok Tercih Edilen</span>
                <i class="fas fa-snowflake"></i>
                <h3>Buzdolabı Servisi</h3>
                <p>Tüm marka buzdolapları için gaz dolumu, motor değişimi ve genel bakım hizmetleri.</p>
            </div>
        </a>

        <a href="@Url.Action("Index", "ServiceRequest", new { kategori = "Çamaşır Makinesi" })" class="service-link">
            <div class="card service-card">
                <i class="fas fa-tshirt"></i>
                <h3>Çamaşır Makinesi Servisi</h3>
                <p>Kart arızaları, rulman değişimi ve su tahliye problemlerine hızlı çözüm.</p>
            </div>
        </a>

        <a href="@Url.Action("Index", "ServiceRequest", new { kategori = "Bulaşık Makinesi" })" class="service-link">
            <div class="card service-card">
                <i class="fas fa-water"></i>
                <h3>Bulaşık Makinesi Servisi</h3>
                <p>Su kaçağı, program hatası gibi tüm sorunlarda yerinde servis sağlıyoruz.</p>
            </div>
        </a>

        <a href="@Url.Action("Index", "ServiceRequest", new { kategori = "Ankastre Fırın" })" class="service-link">
            <div class="card service-card">
                <i class="fas fa-fire"></i>
                <h3>Ankastra Fırın Servisi</h3>
                <p>Ankastra fırınların tüm arızalarında hızlı ve güvenilir servis hizmeti sunuyoruz.</p>
            </div>
        </a>

        <a href="@Url.Action("Index", "ServiceRequest", new { kategori = "Kurutma Makinesi" })" class="service-link">
            <div class="card service-card">
                <i class="fas fa-fan"></i>
                <h3>Kurutma Makinesi Servisi</h3>
                <p>Kurutma makinesi arızaları ve bakımı için profesyonel teknikçilerimiz hizmetinizdedir.</p>
            </div>
        </a>

        <a href="@Url.Action("Index", "ServiceRequest", new { kategori = "Termosifon" })" class="service-link">
            <div class="card service-card">
                <i class="fas fa-droplet"></i>
                <h3>Termosifon Servisi</h3>
                <p>Termosifon onarımı, bakımı ve limanlama işlemlerini güvenli şekilde yapıyoruz.</p>
            </div>
        </a>

        <a href="@Url.Action("Index", "ServiceRequest", new { kategori = "Küçük Ev Aletleri" })" class="service-link">
            <div class="card service-card">
                <i class="fas fa-plug"></i>
                <h3>Küçük Ev Aletleri</h3>
                <p>Mikrodalga, elektrikli ısıtıcı, kahvehane ve diğer küçük ev aletlerinin tamiri.</p>
            </div>
        </a>

    </div>

    <div class="services-cta">
        <div class="services-cta-content">
            <h3>Hemen Servis Talebi Oluştur</h3>
            <a href="@Url.Action("Index", "ServiceRequest")" class="btn services-cta-button">
                <i class="fas fa-headset"></i>
                Hemen Servis Talebi Oluştur
            </a>
        </div>
    </div>
</section>

