@{
    ViewBag.Title = "Hizmetlerimiz - Tekin Teknik Servis";
    Layout = "_Layout";
}

<section class="services-page-section" style="padding: 60px 20px; min-height: 60vh;">
    <div style="text-align: center; margin-bottom: 40px;">
        <h2 style="color: #1e3a8a; font-size: 32px;">Hizmetlerimiz</h2>
        <p style="color: #64748b; font-size: 16px;">Sizlere sunduğumuz profesyonel bakım ve onarım çözümleri</p>
    </div>

    <div class="service-container" style="display: flex; gap: 30px; justify-content: center; flex-wrap: wrap;">
        
        <div class="card" style="width: 300px; padding: 30px; text-align: center; background: white; border-radius: 15px; box-shadow: 0 10px 20px rgba(0,0,0,0.05); transition: transform 0.3s; border-top: 5px solid #2563eb;">
            <i class="fas fa-snowflake" style="font-size: 40px; color: #2563eb; margin-bottom: 15px;"></i>
            <h3 style="color: #1e3a8a; font-size: 22px; margin-bottom: 15px;">Buzdolabı Servisi</h3>
            <p style="color: #475569; line-height: 1.6;">Tüm marka buzdolapları için gaz dolumu, motor değişimi ve genel bakım hizmetleri.</p>
        </div>

        <div class="card" style="width: 300px; padding: 30px; text-align: center; background: white; border-radius: 15px; box-shadow: 0 10px 20px rgba(0,0,0,0.05); transition: transform 0.3s; border-top: 5px solid #2563eb;">
            <i class="fas fa-tshirt" style="font-size: 40px; color: #2563eb; margin-bottom: 15px;"></i>
            <h3 style="color: #1e3a8a; font-size: 22px; margin-bottom: 15px;">Çamaşır Makinesi Servisi</h3>
            <p style="color: #475569; line-height: 1.6;">Kart arızaları, rulman değişimi ve su tahliye problemlerine hızlı çözüm.</p>
        </div>

        <div class="card" style="width: 300px; padding: 30px; text-align: center; background: white; border-radius: 15px; box-shadow: 0 10px 20px rgba(0,0,0,0.05); transition: transform 0.3s; border-top: 5px solid #2563eb;">
            <i class="fas fa-wind" style="font-size: 40px; color: #2563eb; margin-bottom: 15px;"></i>
            <h3 style="color: #1e3a8a; font-size: 22px; margin-bottom: 15px;">Klima Servisi</h3>
            <p style="color: #475569; line-height: 1.6;">Yaz-kış periyodik klima bakımı, montaj, söküm ve petek temizleme işlemleri.</p>
        </div>

    </div>
</section>

