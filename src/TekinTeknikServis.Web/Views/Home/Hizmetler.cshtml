@{
    ViewBag.Title = "Hizmetlerimiz - Tekin Teknik Servis";
    Layout = "_Layout";
}

<section class="services-page-section" style="padding: 60px 20px; min-height: 60vh;">
    <div style="text-align: center; margin-bottom: 40px;">
        <h2 style="color: #1e3a8a; font-size: 32px;">Hizmetlerimiz</h2>
        <p style="color: #64748b; font-size: 16px;">Sizlere sunduğumuz profesyonel bakım ve onarım çözümleri</p>
    </div>

    <div class="service-container" style="display: flex; gap: 30px; justify-content: center; flex-wrap: wrap; max-width: 1400px; margin: 0 auto;">
        
        <a href="@Url.Action("Index", "ServiceRequest", new { kategori = "Buzdolabı" })" style="text-decoration: none; color: inherit;">
            <div class="card" style="width: 300px; padding: 30px; text-align: center; background: white; border-radius: 15px; box-shadow: 0 10px 20px rgba(0,0,0,0.05); transition: all 0.3s; border-top: 5px solid #2563eb; cursor: pointer;" onmouseover="this.style.transform='translateY(-5px)'; this.style.boxShadow='0 15px 30px rgba(0,0,0,0.1)';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 10px 20px rgba(0,0,0,0.05)';">
                <i class="fas fa-snowflake" style="font-size: 40px; color: #2563eb; margin-bottom: 15px;"></i>
                <h3 style="color: #1e3a8a; font-size: 22px; margin-bottom: 15px;">Buzdolabı Servisi</h3>
                <p style="color: #475569; line-height: 1.6;">Tüm marka buzdolapları için gaz dolumu, motor değişimi ve genel bakım hizmetleri.</p>
            </div>
        </a>

        <a href="@Url.Action("Index", "ServiceRequest", new { kategori = "Çamaşır Makinesi" })" style="text-decoration: none; color: inherit;">
            <div class="card" style="width: 300px; padding: 30px; text-align: center; background: white; border-radius: 15px; box-shadow: 0 10px 20px rgba(0,0,0,0.05); transition: all 0.3s; border-top: 5px solid #2563eb; cursor: pointer;" onmouseover="this.style.transform='translateY(-5px)'; this.style.boxShadow='0 15px 30px rgba(0,0,0,0.1)';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 10px 20px rgba(0,0,0,0.05)';">
                <i class="fas fa-tshirt" style="font-size: 40px; color: #2563eb; margin-bottom: 15px;"></i>
                <h3 style="color: #1e3a8a; font-size: 22px; margin-bottom: 15px;">Çamaşır Makinesi Servisi</h3>
                <p style="color: #475569; line-height: 1.6;">Kart arızaları, rulman değişimi ve su tahliye problemlerine hızlı çözüm.</p>
            </div>
        </a>

        <a href="@Url.Action("Index", "ServiceRequest", new { kategori = "Bulaşık Makinesi" })" style="text-decoration: none; color: inherit;">
            <div class="card" style="width: 300px; padding: 30px; text-align: center; background: white; border-radius: 15px; box-shadow: 0 10px 20px rgba(0,0,0,0.05); transition: all 0.3s; border-top: 5px solid #2563eb; cursor: pointer;" onmouseover="this.style.transform='translateY(-5px)'; this.style.boxShadow='0 15px 30px rgba(0,0,0,0.1)';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 10px 20px rgba(0,0,0,0.05)';">
                <i class="fas fa-water" style="font-size: 40px; color: #2563eb; margin-bottom: 15px;"></i>
                <h3 style="color: #1e3a8a; font-size: 22px; margin-bottom: 15px;">Bulaşık Makinesi Servisi</h3>
                <p style="color: #475569; line-height: 1.6;">Su kaçağı, program hatası gibi tüm sorunlarda yerinde servis sağlıyoruz.</p>
            </div>
        </a>

        <a href="@Url.Action("Index", "ServiceRequest", new { kategori = "Ankastre Fırın" })" style="text-decoration: none; color: inherit;">
            <div class="card" style="width: 300px; padding: 30px; text-align: center; background: white; border-radius: 15px; box-shadow: 0 10px 20px rgba(0,0,0,0.05); transition: all 0.3s; border-top: 5px solid #2563eb; cursor: pointer;" onmouseover="this.style.transform='translateY(-5px)'; this.style.boxShadow='0 15px 30px rgba(0,0,0,0.1)';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 10px 20px rgba(0,0,0,0.05)';">
                <i class="fas fa-fire" style="font-size: 40px; color: #2563eb; margin-bottom: 15px;"></i>
                <h3 style="color: #1e3a8a; font-size: 22px; margin-bottom: 15px;">Ankastra Fırın Servisi</h3>
                <p style="color: #475569; line-height: 1.6;">Ankastra fırınların tüm arızalarında hızlı ve güvenilir servis hizmeti sunuyoruz.</p>
            </div>
        </a>

        <a href="@Url.Action("Index", "ServiceRequest", new { kategori = "Kurutma Makinesi" })" style="text-decoration: none; color: inherit;">
            <div class="card" style="width: 300px; padding: 30px; text-align: center; background: white; border-radius: 15px; box-shadow: 0 10px 20px rgba(0,0,0,0.05); transition: all 0.3s; border-top: 5px solid #2563eb; cursor: pointer;" onmouseover="this.style.transform='translateY(-5px)'; this.style.boxShadow='0 15px 30px rgba(0,0,0,0.1)';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 10px 20px rgba(0,0,0,0.05)';">
                <i class="fas fa-fan" style="font-size: 40px; color: #2563eb; margin-bottom: 15px;"></i>
                <h3 style="color: #1e3a8a; font-size: 22px; margin-bottom: 15px;">Kurutma Makinesi Servisi</h3>
                <p style="color: #475569; line-height: 1.6;">Kurutma makinesi arızaları ve bakımı için profesyonel teknikçilerimiz hizmetinizdedir.</p>
            </div>
        </a>

        <a href="@Url.Action("Index", "ServiceRequest", new { kategori = "Termosifon" })" style="text-decoration: none; color: inherit;">
            <div class="card" style="width: 300px; padding: 30px; text-align: center; background: white; border-radius: 15px; box-shadow: 0 10px 20px rgba(0,0,0,0.05); transition: all 0.3s; border-top: 5px solid #2563eb; cursor: pointer;" onmouseover="this.style.transform='translateY(-5px)'; this.style.boxShadow='0 15px 30px rgba(0,0,0,0.1)';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 10px 20px rgba(0,0,0,0.05)';">
                <i class="fas fa-droplet" style="font-size: 40px; color: #2563eb; margin-bottom: 15px;"></i>
                <h3 style="color: #1e3a8a; font-size: 22px; margin-bottom: 15px;">Termosifon Servisi</h3>
                <p style="color: #475569; line-height: 1.6;">Termosifon onarımı, bakımı ve limanlama işlemlerini güvenli şekilde yapıyoruz.</p>
            </div>
        </a>

        <a href="@Url.Action("Index", "ServiceRequest", new { kategori = "Küçük Ev Aletleri" })" style="text-decoration: none; color: inherit;">
            <div class="card" style="width: 300px; padding: 30px; text-align: center; background: white; border-radius: 15px; box-shadow: 0 10px 20px rgba(0,0,0,0.05); transition: all 0.3s; border-top: 5px solid #2563eb; cursor: pointer;" onmouseover="this.style.transform='translateY(-5px)'; this.style.boxShadow='0 15px 30px rgba(0,0,0,0.1)';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 10px 20px rgba(0,0,0,0.05)';">
                <i class="fas fa-plug" style="font-size: 40px; color: #2563eb; margin-bottom: 15px;"></i>
                <h3 style="color: #1e3a8a; font-size: 22px; margin-bottom: 15px;">Küçük Ev Aletleri</h3>
                <p style="color: #475569; line-height: 1.6;">Mikrodalga, elektrikli ısıtıcı, kahvehane ve diğer küçük ev aletlerinin tamiri.</p>
            </div>
        </a>

    </div>
</section>

