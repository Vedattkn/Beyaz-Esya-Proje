@model RegisterViewModel
@{
    ViewBag.Title = "Kayıt Ol - Tekin Teknik Servis";
}

<section class="auth-section">
    <div class="auth-container">
        <!-- Sol Dekoratif Panel -->
        <div class="auth-side-panel">
            <div class="auth-side-content">
                <i class="fas fa-user-shield auth-side-icon"></i>
                <h2>Hoş Geldiniz!</h2>
                <p>Tekin Teknik Servis ailesine katılın. Kayıt olarak hizmetlerimizden kolayca faydalanabilirsiniz.</p>
                <div class="auth-features">
                    <div class="auth-feature-item">
                        <i class="fas fa-check-circle"></i>
                        <span>Servis takibi yapın</span>
                    </div>
                    <div class="auth-feature-item">
                        <i class="fas fa-check-circle"></i>
                        <span>Sipariş geçmişinizi görün</span>
                    </div>
                    <div class="auth-feature-item">
                        <i class="fas fa-check-circle"></i>
                        <span>Özel kampanyalardan yararlanın</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sağ Form Panel -->
        <div class="auth-form-panel">
            <div class="auth-form-header">
                <i class="fas fa-user-plus"></i>
                <h2>Kayıt Ol</h2>
                <p>Hesap oluşturmak için bilgilerinizi girin</p>
            </div>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="auth-alert auth-alert-success">
                    <i class="fas fa-check-circle"></i>
                    <span>@TempData["SuccessMessage"]</span>
                </div>
            }

            <div asp-validation-summary="All" class="auth-alert auth-alert-error validation-errors"></div>

            <form asp-action="Register" method="post" class="auth-form" id="registerForm">
                @Html.AntiForgeryToken()

                <div class="auth-form-group">
                    <label asp-for="AdSoyad">
                        <i class="fas fa-user"></i> Ad Soyad
                    </label>
                    <input asp-for="AdSoyad" class="auth-input" placeholder="Adınızı ve soyadınızı girin" id="registerName" />
                    <span asp-validation-for="AdSoyad" class="auth-error-text"></span>
                </div>

                <div class="auth-form-group">
                    <label asp-for="Email">
                        <i class="fas fa-envelope"></i> E-posta
                    </label>
                    <input asp-for="Email" class="auth-input" placeholder="ornek@email.com" type="email" id="registerEmail" />
                    <span asp-validation-for="Email" class="auth-error-text"></span>
                </div>

                <div class="auth-form-group">
                    <label asp-for="Telefon">
                        <i class="fas fa-phone"></i> Telefon
                    </label>
                    <input asp-for="Telefon" class="auth-input" placeholder="05XX XXX XX XX" id="registerPhone" />
                    <span asp-validation-for="Telefon" class="auth-error-text"></span>
                </div>

                <div class="auth-form-group">
                    <label asp-for="Sifre">
                        <i class="fas fa-lock"></i> Şifre
                    </label>
                    <div class="auth-password-wrapper">
                        <input asp-for="Sifre" class="auth-input" placeholder="En az 6 karakter" type="password" id="registerPassword" />
                        <button type="button" class="auth-password-toggle" onclick="togglePassword('registerPassword', this)">
                            <i class="fas fa-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Sifre" class="auth-error-text"></span>
                    <div class="password-strength" id="passwordStrength">
                        <div class="strength-bar" id="strengthBar"></div>
                    </div>
                    <span class="strength-text" id="strengthText"></span>
                </div>

                <div class="auth-form-group">
                    <label asp-for="SifreTekrar">
                        <i class="fas fa-lock"></i> Şifre Tekrarı
                    </label>
                    <div class="auth-password-wrapper">
                        <input asp-for="SifreTekrar" class="auth-input" placeholder="Şifrenizi tekrar girin" type="password" id="registerPasswordConfirm" />
                        <button type="button" class="auth-password-toggle" onclick="togglePassword('registerPasswordConfirm', this)">
                            <i class="fas fa-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="SifreTekrar" class="auth-error-text"></span>
                </div>

                <button type="submit" class="auth-submit-btn" id="registerSubmitBtn">
                    <i class="fas fa-user-plus"></i> Kayıt Ol
                </button>

                <div class="auth-footer-link">
                    Zaten hesabınız var mı? <a href="@Url.RouteUrl("giris")">Giriş Yapın</a>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
<script>
    function togglePassword(inputId, btn) {
        var input = document.getElementById(inputId);
        var icon = btn.querySelector('i');
        if (input.type === 'password') {
            input.type = 'text';
            icon.classList.remove('fa-eye');
            icon.classList.add('fa-eye-slash');
        } else {
            input.type = 'password';
            icon.classList.remove('fa-eye-slash');
            icon.classList.add('fa-eye');
        }
    }

    // Şifre güçlülük göstergesi
    document.getElementById('registerPassword').addEventListener('input', function () {
        var password = this.value;
        var strength = 0;
        var bar = document.getElementById('strengthBar');
        var text = document.getElementById('strengthText');
        var container = document.getElementById('passwordStrength');

        if (password.length === 0) {
            container.style.display = 'none';
            text.textContent = '';
            return;
        }

        container.style.display = 'block';

        if (password.length >= 6) strength++;
        if (password.length >= 8) strength++;
        if (/[A-Z]/.test(password)) strength++;
        if (/[0-9]/.test(password)) strength++;
        if (/[^A-Za-z0-9]/.test(password)) strength++;

        var width = (strength / 5) * 100;
        bar.style.width = width + '%';

        if (strength <= 1) {
            bar.style.background = '#ef4444';
            text.textContent = 'Zayıf';
            text.style.color = '#ef4444';
        } else if (strength <= 2) {
            bar.style.background = '#f97316';
            text.textContent = 'Orta';
            text.style.color = '#f97316';
        } else if (strength <= 3) {
            bar.style.background = '#eab308';
            text.textContent = 'İyi';
            text.style.color = '#eab308';
        } else {
            bar.style.background = '#22c55e';
            text.textContent = 'Güçlü';
            text.style.color = '#22c55e';
        }
    });
</script>
}
