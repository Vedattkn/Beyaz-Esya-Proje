@model TekinTeknikServis.Core.Models.ServiceRequestForm
@{
    ViewBag.Title = "Servis Talep";
    Layout = "_Layout";
}

<section class="service-request-section">
    <div class="form-container">
        <div class="form-header">
            <i class="fas fa-tools"></i>
            <h2>Servis Talebi Oluştur</h2>
            <p>Aşağıdaki formu doldurarak uzman ekiplerimizin sizinle en kısa sürede iletişime geçmesini sağlayabilirsiniz.</p>
        </div>

        @if (ViewBag.Success == true)
        {
            <div class="success-alert">
                <i class="fas fa-check-circle"></i>
                <p>Servis talebiniz başarıyla alınmıştır! En kısa sürede sizinle iletişime geçilecektir.</p>
            </div>
        }

        <form asp-controller="ServiceRequest" asp-action="Index" method="post" class="modern-service-form">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="validation-errors"></div>

            <div class="form-group">
                <label asp-for="AdSoyad"><i class="fas fa-user"></i> Ad Soyad</label>
                <input asp-for="AdSoyad" placeholder="Adınızı ve soyadınızı giriniz" required />
                <span asp-validation-for="AdSoyad" class="error-text"></span>
            </div>

            <div class="form-group">
                <label asp-for="Telefon"><i class="fas fa-phone"></i> Telefon (11 Hane)</label>
                <input asp-for="Telefon" placeholder="05xxxxxxxxx" required maxlength="11" pattern="[0-9]{11}" />
                <span asp-validation-for="Telefon" class="error-text"></span>
            </div>

            <div class="form-group">
                <label asp-for="CihazTuru"><i class="fas fa-blender"></i> Cihaz Türü</label>
                <select asp-for="CihazTuru" class="form-input" style="width: 100%; height: auto;" required>
                    <option value="">Seçiniz</option>
                    @if (ViewBag.DeviceTypes != null)
                    {
                        foreach (string dt in ViewBag.DeviceTypes)
                        {
                            <option value="@dt">@dt</option>
                        }
                    }
                </select>
                <span asp-validation-for="CihazTuru" class="error-text"></span>
            </div>

            <div class="form-group">
                <label asp-for="ArizaAciklamasi"><i class="fas fa-comment-alt"></i> Arıza Açıklaması</label>
                <textarea asp-for="ArizaAciklamasi" rows="4" placeholder="Cihazdaki sorunu kısaca anlatınız..." required></textarea>
                <span asp-validation-for="ArizaAciklamasi" class="error-text"></span>
            </div>

            <button type="submit" class="submit-btn">
                <span>Talebi Gönder</span>
                <i class="fas fa-paper-plane"></i>
            </button>
        </form>
    </div>
</section>


